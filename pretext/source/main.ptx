<?xml version='1.0' encoding='utf-8'?>
<!-- This is the main file of the PreTeXt version of                 -->
<!-- "R Markdown: The Definitive Guide"                              -->
<!-- by Yihui Xie, J. J. Allaire, and Garrett Grolemund.            -->
<!-- The main.ptx file imports other .ptx files which contain        -->
<!-- the book content, organized to mirror the original RMD book.   -->

<pretext xml:lang="en-US" xmlns:xi="http://www.w3.org/2001/XInclude">

  <!-- we first include a file which contains the docinfo element: -->
  <xi:include href="./meta_docinfo.ptx" />

  <book xml:id="rmarkdown-definitive-guide">
    <title>R Markdown: The Definitive Guide</title>
    <subtitle>A PreTeXt Edition</subtitle>

    <!-- Front matter: preface, about the authors, abstract -->
    <xi:include href="./meta_frontmatter.ptx" />

    <!-- Part I: Get Started -->
    <part xml:id="part-get-started">
      <title>Get Started</title>
      <xi:include href="./ch_installation.ptx" />
      <xi:include href="./ch_basics.ptx" />
    </part>

    <!-- Part II: Output Formats -->
    <part xml:id="part-output-formats">
      <title>Output Formats</title>
      <xi:include href="./ch_documents.ptx" />
      <xi:include href="./ch_presentations.ptx" />
    </part>

    <!-- Part III: Extensions -->
    <part xml:id="part-extensions">
      <title>Extensions</title>
      <xi:include href="./ch_dashboards.ptx" />
      <xi:include href="./ch_tufte.ptx" />
      <xi:include href="./ch_xaringan.ptx" />
      <xi:include href="./ch_revealjs.ptx" />
      <xi:include href="./ch_community.ptx" />
      <xi:include href="./ch_website.ptx" />
      <xi:include href="./ch_pkgdown.ptx" />
      <xi:include href="./ch_bookdown.ptx" />
      <xi:include href="./ch_rticles.ptx" />
      <xi:include href="./ch_learnr.ptx" />
    </part>

    <!-- Part IV: Other Topics -->
    <part xml:id="part-other-topics">
      <title>Other Topics</title>
      <xi:include href="./ch_parameterized.ptx" />
      <xi:include href="./ch_widgets.ptx" />
      <xi:include href="./ch_templates.ptx" />
      <xi:include href="./ch_new_formats.ptx" />
      <xi:include href="./ch_shiny.ptx" />
    </part>

    <!-- Back matter: references and index -->
    <xi:include href="./meta_backmatter.ptx" />
  </book>
</pretext>
